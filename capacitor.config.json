{
    "appId": "com.personal.tasktrack",
    "appName": "TaskTrack",
    "webDir": "dist",
    "server": {
        "androidScheme": "https"
    },
    "plugins": {
        "SplashScreen": {
            "launchShowDuration": 2000,
            "backgroundColor": "#0F0F1A",
            "showSpinner": false,
            "androidSplashResourceName": "splash",
            "splashFullScreen": true,
            "splashImmersive": true
        },
        "StatusBar": {
            "style": "DARK",
            "backgroundColor": "#0F0F1A"
        }
    }
}